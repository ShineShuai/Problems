{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_CXX_COMPILER=/usr/local/opt/llvm/bin/clang++" // clang++ for c++, or ld symbols not found for x86_64
            ],
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "C/C++: clang build sources",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "${fileDirnameBasename}",
                "--config",
                "Debug",
                "-j4"
            ],
            "dependsOn": [
                "CMake: Configure"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always", // Shows full output
                "panel": "shared"
            }
        }
    ]
}
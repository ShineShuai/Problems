{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_CXX_COMPILER=/usr/local/opt/llvm/bin/clang++" // clang++ for c++, or ld symbols not found for x86_64
            ],
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "C/C++: clang build sources",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--target", "${fileDirnameBasename}",
                "--config", "Debug",
                "-j4"
            ],
            "dependsOn": [
                "CMake: Configure"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always", // Shows full output
                "panel": "shared"
            }
        },
        {
            "label": "CMake: Build Tests",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--target", "cpptests",
                "--config", "Debug",
                "-j4"
            ],
            "dependsOn": ["CMake: Configure"],
            "group": { "kind": "build", "isDefault": false },
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Run All Tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir", "${workspaceFolder}/build",
                "--output-on-failure"
            ],
            "dependsOn": ["CMake: Build Tests"],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Run Current Test",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir", "${workspaceFolder}/build",
                "-R", "${fileBasenameNoExtension}",
                "--output-on-failure"
            ],
            "dependsOn": ["CMake: Build Tests"],
            "group": "test",
            "problemMatcher": []
        }
    ]
}
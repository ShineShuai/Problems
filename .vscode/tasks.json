{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Create Build Directories",
            "type": "shell",
            "command": "mkdir",
            "args": [
                "-p",
                "${fileDirname}/build/"
            ],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file",
            "command": "/usr/bin/clang++",  // clang++ for c++, or ld symbols not found for x86_64
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "-std=c++17", 
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-Weffc++",
                "-Werror",
                "-o",
                "${fileDirname}/build/${fileDirnameBasename}",
                "${fileDirname}/*.cpp"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger.",
            "presentation": {
                "reveal": "always",            // Shows full output
                "panel": "shared"
            }
        }
    ]
}